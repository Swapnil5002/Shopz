# Stripe Checkout configuration (test mode)
# Copy this file to `.env` and fill in your keys to enable live checkout.
# Vite only exposes variables prefixed with VITE_ to the frontend.

# Frontend publishable key (safe to expose in the browser bundle):
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Payment flow: "mock" (default, no real charges) or "live" (real Stripe).
# Live mode requires a backend endpoint that creates Checkout Sessions.
VITE_CHECKOUT_MODE=mock

# IMPORTANT: your Stripe SECRET key must live ONLY on a backend server and
# must NEVER be committed or exposed to the frontend. It is listed here only
# as a reminder for when you add a backend (do not prefix it with VITE_).
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
